# =============================================================
# KAIROS CABLE TV SAAS - LIVE DATABASE CONNECTION CONFIG
# =============================================================

# Instructions:
# 1. Rename this file from `.env.example` to `.env` in the root folder.
# 2. Replace the placeholder values below with your actual Supabase credentials.
# 3. Restart your dev server (`npm run dev`) to apply the changes.

# Your Supabase Project API URL (found in Project Settings -> API)
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Your Supabase Anonymous Public Key (found in Project Settings -> API)
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-anon-key-here
